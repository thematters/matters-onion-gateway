# Placeholder values only. Do not commit real secrets.

NODE_ENV=production
PORT=3000

MATTERS_GRAPHQL_ENDPOINT=https://server.matters.news/graphql

IPFS_LOCAL_GATEWAY=http://127.0.0.1:8080
IPFS_FALLBACK_GATEWAY=https://ipfs.io

IMAGE_PROXY_MAX_BYTES=5242880
UPSTREAM_TIMEOUT_MS=8000

# Home/channel feed in-memory cache TTL (ms) and the global cap on concurrent
# upstream GraphQL requests. Both protect the single instance and the Matters
# backend. The concurrency cap is global on purpose: all Tor traffic arrives from
# the local Tor daemon, so per-IP limiting would be meaningless.
FEED_CACHE_TTL_MS=45000
MAX_UPSTREAM_CONCURRENCY=6
