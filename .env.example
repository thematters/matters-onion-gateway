# Placeholder values only. Do not commit real secrets.

NODE_ENV=production
PORT=3000

MATTERS_GRAPHQL_ENDPOINT=https://server.matters.news/graphql

IPFS_LOCAL_GATEWAY=http://127.0.0.1:8080
IPFS_FALLBACK_GATEWAY=https://ipfs.io

IMAGE_PROXY_MAX_BYTES=5242880
UPSTREAM_TIMEOUT_MS=8000

# Comma-separated hosts the image proxy may fetch from. Configured IPFS gateway
# hosts are always allowed in addition to this list. Leave unset to use the
# Matters defaults (assets.matters.news, imagedelivery.net).
IMAGE_PROXY_ALLOWED_HOSTS=assets.matters.news,imagedelivery.net
